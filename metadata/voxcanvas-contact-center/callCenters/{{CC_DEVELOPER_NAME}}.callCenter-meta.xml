<?xml version="1.0" encoding="UTF-8"?>
<CallCenter xmlns="http://soap.sforce.com/2006/04/metadata">
    <!--
         CRITICAL schema notes (this file has been wrong TWICE already —
         do not "simplify" without reading this comment):

         1. Root element is <CallCenter> (CAPITAL C), NOT <callCenter>.
            sf CLI's source-deploy-retrieve registry expects the
            Metadata-API type name casing for the root element. The
            lowercase <callCenter> variant is a separate XML format
            used only by Salesforce Setup UI's "Import" button and is
            NOT accepted by `sf project deploy start`.

         2. xmlns IS required. The previous "fix" that removed it was
            wrong — Setup-UI import XML is no-namespace, but sf CLI
            source-format CallCenter IS in the standard metadata
            namespace. Without xmlns, the validator rejects every
            child element with "Element {}section invalid".

         3. Structure is <sections>/<items> (PLURAL) with children
            <name>/<label>/<value>. Attribute-style <section sortOrder=...>
            is the Setup-UI import format. The Metadata API schema
            for CallCenter uses named child elements. Getting this
            wrong produces "Element section invalid at this location
            in type CallCenter" regardless of namespace.

         Authoritative reference: retrieve any real CallCenter from
         an org via `sf project retrieve start --metadata CallCenter:X`.
         Real-world Metadata-API source-format examples on GitHub:
         github.com/swongcopado/swenuc2repo/blob/master/callCenters/OpenCTI.callCenter

         The <displayName> and <internalNameLabel>/<displayNameLabel>
         fields at the CallCenter level mirror the "Internal Name" /
         "Display Name" labels shown in Setup UI.

         reqRelayState / reqIdentityUrl are IdP-initiated SSO fields
         VoxCanvas does not implement, but the Partner Telephony
         validator still requires the items to be present (with
         empty <value>) so they are kept in the payload.

         reqTelephonyIntegrationCertificate receives the JWT public
         key PEM so the admin does not have to paste it into the
         Contact Center's Public Key field via Setup UI.

         The filename contains the {{CC_DEVELOPER_NAME}} placeholder
         because sf CLI source-format requires the filename to match
         the InternalName — it is renamed at render time.
    -->
    <displayName>{{CC_MASTER_LABEL}}</displayName>
    <displayNameLabel>Display Name</displayNameLabel>
    <internalNameLabel>Internal Name</internalNameLabel>
    <sections>
        <items>
            <label>Internal Name</label>
            <name>reqInternalName</name>
            <value>{{CC_DEVELOPER_NAME}}</value>
        </items>
        <items>
            <label>Display Name</label>
            <name>reqDisplayName</name>
            <value>{{CC_MASTER_LABEL}}</value>
        </items>
        <items>
            <label>Conversation Vendor Info Developer Name</label>
            <name>reqVendorInfoApiName</name>
            <value>VoxCanvas</value>
        </items>
        <label>General Information</label>
        <name>reqGeneralInfo</name>
    </sections>
    <sections>
        <items>
            <label>Relay State</label>
            <name>reqRelayState</name>
            <value></value>
        </items>
        <items>
            <label>Identity URL</label>
            <name>reqIdentityUrl</name>
            <value></value>
        </items>
        <items>
            <label>Telephony Integration Certificate</label>
            <name>reqTelephonyIntegrationCertificate</name>
            <value>{{JWT_PEM}}</value>
        </items>
        <items>
            <label>Long Distance Prefix</label>
            <name>reqLongDistPrefix</name>
            <value>+1</value>
        </items>
        <items>
            <label>Universal Call Recording Access</label>
            <name>reqUniversalCallRecordingAccess</name>
            <value>false</value>
        </items>
        <label>SCV Settings</label>
        <name>reqHvcc</name>
    </sections>
</CallCenter>

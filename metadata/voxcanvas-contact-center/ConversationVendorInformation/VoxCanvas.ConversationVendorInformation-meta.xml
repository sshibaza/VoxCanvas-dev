<?xml version="1.0" encoding="UTF-8"?>
<ConversationVendorInfo xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <developerName>VoxCanvas</developerName>
    <masterLabel>VoxCanvas Partner Telephony</masterLabel>
    <vendorType>ServiceCloudVoicePartner</vendorType>
    <connectorUrl>{{SERVICE_ENDPOINT}}</connectorUrl>
    <!-- ServiceCloudVoicePartner vendor metadata is ALWAYS validated
         against the presence of <integrationClass>, even when every
         *Supported flag is false. VoxCanvasTelephonyStub is a minimal
         Apex class shipped alongside this file (deployed in the same
         payload) that satisfies the platform check without VoxCanvas
         needing any real Apex logic. -->
    <integrationClass>VoxCanvasTelephonyIntegration</integrationClass>
    <!-- Every *Supported flag that the validator says requires an
         IntegrationClass implementation is explicitly disabled so the
         ServiceCloudVoicePartner vendor type doesn't enable them by
         default. VoxCanvas ships only an empty stub Apex class.

         keyProvisioningSupported=false is intentional: VoxCanvas uses
         manual JWT public-key entry (the wizard Step 3 instructs the
         admin to paste certs/jwt.pem into the Contact Center's Public
         Key field via Setup UI). keyProvisioningSupported=true would
         require the integrationClass to implement
         service_cloud_voice.KeyProvider and would reject deploys that
         don't. -->
    <keyProvisioningSupported>false</keyProvisioningSupported>
    <einsteinConversationInsightsSupported>false</einsteinConversationInsightsSupported>
    <userSyncingSupported>false</userSyncingSupported>
    <partnerTransferDestinationsSupported>false</partnerTransferDestinationsSupported>
    <partnerContactCenterListSupported>false</partnerContactCenterListSupported>
    <agentSSOSupported>false</agentSSOSupported>
</ConversationVendorInfo>

    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.10",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8"
  }
